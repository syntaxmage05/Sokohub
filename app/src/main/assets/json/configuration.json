{
  "settings": {
    "screenshots_enabled": true
  },
  "rules": [
    {
      "patterns": ["^.*"],
      "properties": {
        "context": "default",
        "uri": "sokohub://fragment/web",
        "pull_to_refresh_enabled": true
      }
    },
    {
      "patterns": [
        "^$",
        "^/$",
        "^/profile$",
        "^/my_listings$"
      ],
      "properties": {
        "uri": "sokohub://fragment/web/tab",
        "presentation": "replace_root"
      }
    },
    {
      "patterns": [
        "^/login$",
        "^/sign_up$",
        "^/users/password_resets/.*",
        "^/new$",
        "^/edit$"
      ],
      "properties": {
        "context": "modal",
        "uri": "sokohub://fragment/web/modal"
      }
    },
    {
      "patterns": [
        ".+\\.(?:bmp|gif|heic|jpg|jpeg|png|svg|webp)"
      ],
      "properties": {
        "uri": "sokohub://fragment/image_viewer"
      }
    }
  ]
}